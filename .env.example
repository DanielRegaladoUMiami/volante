# Volante environment — copy to .env and fill. NEVER commit .env (it's gitignored).
# Secrets go here, not in chat or in the repo.

# --- Waitlist storage (M2) ---
# Local default is SQLite (no value needed). For Supabase/Postgres later:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Protects /admin/waitlist once deployed (unset = open for local dev).
# VOLANTE_ADMIN_TOKEN=choose-a-long-random-string

# --- Wired in M3 (not needed yet) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
